# Copy this file to .env and fill values locally.
# Never commit real secrets.

LLM_PROVIDER=huggingface
HF_API_TOKEN=your_huggingface_token_here
HF_MODEL=google/flan-t5-base
# Optional: custom inference endpoint URL
# HF_API_URL=

# Alternative provider: groq
# LLM_PROVIDER=groq
# GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.1-8b-instant

OPENAI_API_KEY=your_openai_api_key_here
CONCIERGE_MODEL=gpt-4o-mini

CUSTOMER_AGENT_URL=http://127.0.0.1:8201
DEAL_AGENT_URL=http://127.0.0.1:8202
MARKETING_AGENT_URL=http://127.0.0.1:8203
